# obsidian-sync configuration
# This template is used by /configure to generate your config.
# Config is saved to the resolved obsidian-sync config path.

# Obsidian vault name (used for `obsidian` CLI vault= parameter)
vault_name: ""

# Absolute path to your vault (used for direct file write fallback)
vault_path: ""

# qmd collection name for indexing and search
qmd_collection: ""

# Folder structure within the vault
folders:
  sessions: "{{ plugin.default_folders.sessions }}"
  learnings: "{{ plugin.default_folders.learnings }}"
  tasks: "{{ plugin.default_folders.tasks }}"
  ideas: "{{ plugin.default_folders.ideas }}"
  canvas: "{{ plugin.default_folders.canvas }}"
  dashboard: "{{ plugin.default_folders.dashboard }}"

# Search mode: "hybrid" uses qmd query (BM25 + vector + LLM re-ranking, requires embeddings),
# "keyword" uses qmd search only (BM25, no embedding needed — faster and lighter)
search_mode: "hybrid"

# Language for note content (templates and structure remain unchanged)
content_language: "English"

# Tags applied to all generated notes before the runtime adds its provenance tag
default_tags:
  - {{ plugin.common_tag }}
