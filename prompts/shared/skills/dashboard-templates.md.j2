## tasks.base

```yaml
filters:
  and:
    - file.inFolder("${folders.tasks}")
    - 'type == "task"'

formulas:
  age: '(today() - date(date)).days'
  priority_icon: 'if(priority == "P0", "🔴 P0", if(priority == "P1", "🟠 P1", if(priority == "P2", "🟡 P2", "🟢 P3")))'
  status_icon: 'if(status == "done", "✅ Done", if(status == "in-progress", "🔄 In Progress", "📋 Open"))'

properties:
  file.name:
    displayName: "Task"
  project:
    displayName: "Project"
  formula.priority_icon:
    displayName: "Priority"
  formula.status_icon:
    displayName: "Status"
  date:
    displayName: "Created"
  formula.age:
    displayName: "Days Ago"

views:
  - type: table
    name: "Active Tasks"
    filters:
      and:
        - 'status != "done"'
    order:
      - file.name
      - project
      - formula.priority_icon
      - formula.status_icon
      - date
      - formula.age
    groupBy:
      property: priority
      direction: ASC
    summaries:
      file.name: Filled

  - type: table
    name: "Active Tasks Overview"
    limit: 5
    filters:
      and:
        - 'status != "done"'
    order:
      - file.name
      - project
      - formula.priority_icon
      - formula.status_icon
      - date

  - type: table
    name: "Completed"
    filters:
      and:
        - 'status == "done"'
    order:
      - file.name
      - project
      - formula.priority_icon
      - date
    summaries:
      file.name: Filled

  - type: table
    name: "All Tasks"
    order:
      - file.name
      - project
      - formula.priority_icon
      - formula.status_icon
      - date
      - formula.age
    summaries:
      file.name: Filled
      date: Latest
```

